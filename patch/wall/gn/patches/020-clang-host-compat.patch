+
+def get_clang_major_version(cxx):
+  """Return Clang's major version, or None when cxx is not Clang."""
+  ret = subprocess.run(
+      f'{cxx} -dM -E -x c++ -',
+      shell=True,
+      stdin=subprocess.DEVNULL,
+      text=True,
+      capture_output=True)
+  if ret.returncode != 0 or "#define __clang__" not in ret.stdout:
+    return None
+
+  match = re.search(r'^#define __clang_major__\s+(\d+)$',
+                    ret.stdout, re.MULTILINE)
+  return int(match.group(1)) if match else None
+
